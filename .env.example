# EMRID Operations — environment template.
#
# Sprint 1 is a UI/architecture-only foundation: there is NO AWS, Cognito,
# DynamoDB, or S3 integration yet. The three adapter flags below exist now so
# the configuration spine matches the patient platform and future sprints can
# migrate each subsystem independently. They default to "mock" outside
# production and fail closed in production (see lib/config).
#
# NONE of these are required to run the Sprint 1 shell locally.

# --- App ---
# APP_ENV=development
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Adapter flags (server-only — NOT NEXT_PUBLIC) ---
# USE_MOCK_AUTH=true      # mock Ops identity vs Cognito (future)
# USE_MOCK_DATA=true      # in-memory store vs DynamoDB (future)
# USE_MOCK_UPLOADS=true   # mock URLs vs S3 presigned uploads (future)

# --- AWS (future sprints — shared infra with the patient platform) ---
# APP_AWS_REGION=eu-west-1
# DYNAMODB_TABLE_NAME=emrid-dev-app
# S3_DOCUMENT_BUCKET=emrid-dev-documents

# --- Cognito (future sprints — public app client, inlined at build) ---
# NEXT_PUBLIC_COGNITO_USER_POOL_ID=
# NEXT_PUBLIC_COGNITO_CLIENT_ID=
# NEXT_PUBLIC_COGNITO_REGION=eu-west-1
